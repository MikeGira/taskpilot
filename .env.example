# ─── App ─────────────────────────────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash). Update after first deploy.
NEXT_PUBLIC_SITE_URL=https://taskpilot.vercel.app

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# ⚠️  SERVICE ROLE KEY — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Dashboard → Products → your product → Price ID
STRIPE_PRICE_ID=price_...

# ─── Resend ───────────────────────────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_...
# Must be a verified domain in Resend (e.g., hello@taskpilot.dev)
RESEND_FROM_EMAIL=hello@taskpilot.dev

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used to sign HMAC unsubscribe tokens — keep secret
UNSUB_HMAC_SECRET=

# ─── Internal ─────────────────────────────────────────────────────────────────
# Your email for admin notifications (contact form, new purchases)
ADMIN_EMAIL=your@email.com
